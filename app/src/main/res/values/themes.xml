<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SEAPEDIA" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/white_gray</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/black</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="PrimaryButton">
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">#2563EB</item>
    </style>

    <style name="OutlineButton">
        <item name="android:textColor">@color/blue</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/black</item>
    </style>

    <style name="RatingBarTint">
        <item name="colorControlActivated">#FBBF24</item>
        <item name="colorControlNormal">@color/gray</item>
    </style>

    <style name="Theme.SEACatering.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.SEAPEDIA</item>
    </style>
</resources>